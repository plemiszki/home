#!/bin/bash
rm -rf ~/.cache/chromium
DISPLAY=:0 xset s off
DISPLAY=:0 xset -dpms
DISPLAY=:0 xset s noblank
DISPLAY=:0 unclutter-xfixes --hide-on-touch &
DISPLAY=:0 chromium --start-fullscreen --enable-features=OverlayScrollbar --incognito --kiosk --touch-events=enabled --password-store=basic --enable-gpu-vsync http://127.0.0.1:5000
